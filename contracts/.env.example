# RPC + explorer
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_ONE_RPC=https://arb1.arbitrum.io/rpc
ARBISCAN_API_KEY=

# Deployer (NEVER commit — use a throwaway for testnet)
DEPLOYER_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# iExec Nox pre-deployed addresses on Arbitrum Sepolia
# Source: https://github.com/iExec-Nox/demo-ctoken (README)
# ---------------------------------------------------------------------------
# Confidential tokens (ERC-7984)
COLLATERAL_TOKEN=0x92b23f4a59175415ced5cb37e64a1fc6a9d79af4  # cRLC
DEBT_TOKEN=0x1ccec6bc60db15e4055d43dc2531bb7d4e5b808e        # cUSDC

# Underlying plaintext ERC-20 addresses — used only as "asset keys" for the oracle.
COLLATERAL_ASSET=0x9923eD3cbd90CD78b910c475f9A731A6e0b8C963   # RLC
DEBT_ASSET=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d         # USDC

# Nox core compute contract — the vault does not call it directly, but the
# Nox.sol library resolves it automatically from chainid. Recorded here for ops.
NOX_COMPUTE=0xd464B198f06756a1d00be223634b85E0a731c229

# ---------------------------------------------------------------------------
# Oracle wiring (optional — the deploy script uses manual overrides by default
# since RLC/USD isn't published by Chainlink on Sepolia.)
# ---------------------------------------------------------------------------
# Initial manual prices in 8 decimals (e.g. 150_000_000 = $1.50).
COLLATERAL_INITIAL_PRICE_USD_8DEC=150000000
DEBT_INITIAL_PRICE_USD_8DEC=100000000

# For the push-price helper script
ORACLE_ADDRESS=
VAULT_ADDRESS=
PRICE_ASSET=
PRICE_USD_8DEC=
